# ==============================================================================
# LIFE TIME CREDENTIALS
# ==============================================================================
LIFETIME_USERNAME=your_email@example.com
LIFETIME_PASSWORD=your_password

# Club name EXACTLY as it appears on the Life Time schedule page.
# This is passed as the ``locations`` parameter to the schedules API,
# so it must match verbatim (spaces, numbers, "at", etc.).
# Find your club name at: https://my.lifetime.life/view-all-clubs.html
# Examples:
#   San Antonio 281
#   Flower Mound
#   Plano
LIFETIME_CLUB_NAME=San Antonio 281

# ==============================================================================
# TARGET CLASS CONFIGURATION
# ==============================================================================
# The bot fetches the day's schedule from
#   https://api.lifetimefitness.com/ux/web-schedules/v2/schedules/classes
# and picks the first class that matches TARGET_CLASS + TARGET_INSTRUCTOR +
# START_TIME + END_TIME. View your schedule in a browser at:
#   https://my.lifetime.life/clubs/{state}/{club}/classes.html

# Class name - does NOT need to be the full class title
# The bot matches if TARGET_CLASS is CONTAINED within the class title (case-insensitive)
# Use just enough of the name to uniquely identify the class you want
#
# Examples:
#   "Pickleball" matches "Pickleball Open Play", "Pickleball Skills", etc.
#   "ALPHA CONDITIONING" matches "ALPHA CONDITIONING: HINGE + PRESS"
#   "ALPHA STRENGTH" matches "ALPHA STRENGTH: SQUAT + LUNGE"
#   "GTX" matches "GTX: HINGE + PRESS", "GTX: SQUAT + LUNGE", etc.
#
# Be specific enough to avoid matching the wrong class!
TARGET_CLASS=Pickleball

# Instructor name as displayed (typically "FirstName L" format, no period after initial)
# Leave blank, or use values like "any", "none", or "ignore" to disable instructor filtering
TARGET_INSTRUCTOR=John D

# Date in YYYY-MM-DD format
# Note: Ignored if RUN_ON_SCHEDULE=true (calculates as today + 8 days)
TARGET_DATE=2025-01-15

# Start and end times EXACTLY as shown on schedule
START_TIME=9:00 AM
END_TIME=10:00 AM

# ==============================================================================
# NOTIFICATION SETTINGS
# ==============================================================================
# Options: email, sms, both
NOTIFICATION_METHOD=email

# ==============================================================================
# EMAIL CONFIGURATION
# Required if NOTIFICATION_METHOD is "email" or "both"
# ==============================================================================
# For Gmail: Use an App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_RECEIVER=recipient@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ==============================================================================
# SMS CONFIGURATION (Twilio)
# Only required if NOTIFICATION_METHOD is "sms" or "both"
# ==============================================================================
# Sign up for free at: https://www.twilio.com/try-twilio
# Free trial includes $15 credit (~1,800+ SMS messages)
#
# Find your credentials at: https://console.twilio.com
# Account SID and Auth Token are on the main dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number (from the console, format: +1XXXXXXXXXX)
TWILIO_FROM_NUMBER=+15551234567

# Your personal phone number to receive SMS (format: +1XXXXXXXXXX)
SMS_NUMBER=+15129819861

# Schedule mode:
#   true  = Calculate TARGET_DATE as today + 8 days (for GitHub Actions)
#   false = Use the TARGET_DATE specified above (for manual runs)
RUN_ON_SCHEDULE=false

# Target time configuration (only used when RUN_ON_SCHEDULE=true)
# Specify your local time and timezone - DST is handled automatically
# Common timezones: America/Chicago, America/New_York, America/Los_Angeles, America/Denver
TARGET_LOCAL_TIME=10:00:00
TIMEZONE=America/Chicago

# Advanced runtime options
# MAX_RETRIES and RETRY_DELAY_SECONDS are honored by local runs.
# GitHub Actions currently wires NOTIFICATION_TIMEOUT_SECONDS and SMTP_TIMEOUT_SECONDS.
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
NOTIFICATION_TIMEOUT_SECONDS=300
SMTP_TIMEOUT_SECONDS=300
